{
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "content.js" ],
      "matches": [ "https://plc-mt.logistics.pdisoftware.com/*" ],
      "run_at": "document_start"
   } ],
   "host_permissions": [ "https://plc-mt.logistics.pdisoftware.com/*", "https://svc-scheduling.logistics.pdisoftware.com/*" ],
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "PDI Trips Exporter",
   "permissions": [ "storage", "downloads" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0.3",
   "web_accessible_resources": [ {
      "matches": [ "https://plc-mt.logistics.pdisoftware.com/*" ],
      "resources": [ "page_hook.js" ]
   } ]
}
